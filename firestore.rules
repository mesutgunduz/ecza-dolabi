rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function hasFamilyDoc(familyCode) {
      return exists(/databases/$(database)/documents/families/$(familyCode));
    }

    function validFamilyDocShape(familyCode) {
      let family = get(/databases/$(database)/documents/families/$(familyCode)).data;
      return family.familyCode == familyCode
        && family.familyPassword is string
        && family.familyPassword.size() >= 4;
    }

    function familyOk(familyCode) {
      return hasFamilyDoc(familyCode) && validFamilyDocShape(familyCode);
    }

    // NOTE: This app has no Firebase Authentication.
    // The familyCode + familyPassword pair acts as the shared secret.
    // True per-user isolation requires adding Firebase Auth in the next phase.

    match /families/{familyCode} {
      // Block listing all family codes.
      allow list: if false;

      // Allow reading the family root doc (needed for login / password check).
      // LIMITATION: anyone who guesses a familyCode can read the password hash.
      // Mitigated by: familyCode must be known (not guessable from the outside
      // because listing is blocked), and passwords are validated app-side.
      allow get: if true;

      // Family root may be created once with required fields only.
      allow create: if request.resource.data.keys().hasOnly([
                        'familyCode', 'familyPassword', 'createdAt', 'updatedAt', 'migratedFromLegacy'
                      ])
        && request.resource.data.familyCode == familyCode
        && request.resource.data.familyPassword is string
        && request.resource.data.familyPassword.size() >= 4
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;

      // Allow updates but keep familyCode immutable; require valid password field.
      allow update: if request.resource.data.familyCode == resource.data.familyCode
        && request.resource.data.familyPassword is string
        && request.resource.data.familyPassword.size() >= 4
        && request.resource.data.updatedAt is number;

      // Never delete the family root doc from client.
      allow delete: if false;

      // --- persons subcollection ---
      match /persons/{docId} {
        allow read: if familyOk(familyCode);
        allow create: if familyOk(familyCode)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0;
        allow update: if familyOk(familyCode)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0;
        allow delete: if familyOk(familyCode);
      }

      // --- meds subcollection ---
      match /meds/{docId} {
        allow read: if familyOk(familyCode);
        allow create: if familyOk(familyCode)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.personId is string;
        allow update: if familyOk(familyCode)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0;
        allow delete: if familyOk(familyCode);
      }

      // --- logs subcollection ---
      match /logs/{docId} {
        allow read: if familyOk(familyCode);
        allow create: if familyOk(familyCode)
          && request.resource.data.medId is string
          && request.resource.data.personId is string
          && request.resource.data.date is string;
        allow update: if familyOk(familyCode);
        allow delete: if familyOk(familyCode);
      }

      // --- meta subcollection (reorderCart etc.) ---
      match /meta/{docId} {
        allow read, write: if familyOk(familyCode);
      }

      // Block any other subcollection entirely.
      match /{unknownCollection}/{docId} {
        allow read, write: if false;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
